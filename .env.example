# ---------------------------------------------------------------------------
# RN Ideallinie — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ---------------------------------------------------------------------------

# PostgreSQL connection (with PostGIS)
DATABASE_URL="postgresql://postgres:password@localhost:5432/rn_ideallinie?schema=public"

# Solver microservice (Python/FastAPI)
SOLVER_SERVICE_URL="http://localhost:8001"

# Track service
TRACK_SERVICE_URL="http://localhost:8002"

# Trajectory service
TRAJECTORY_SERVICE_URL="http://localhost:8003"

# API Gateway
API_PORT=3000

# Frontend (Vite)
VITE_API_BASE_URL="http://localhost:3000"
